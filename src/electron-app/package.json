{
  "name": "termflow",
  "version": "0.1.0",
  "description": "Korean-English bilingual dictation for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "build": {
    "appId": "com.termflow.app",
    "productName": "TermFlow",
    "mac": {
      "target": ["dmg", "zip"],
      "sign": null
    },
    "extraResources": [
      {"from": "../sidecar", "to": "sidecar", "filter": ["!venv", "!__pycache__", "!**/__pycache__"]},
      {"from": "../swift-audio/recorder", "to": "recorder"}
    ]
  }
}
